{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for ClipB",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",

    "sql:default",
    "sql:allow-execute",

    "dialog:default",

    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file"
  ]
}
