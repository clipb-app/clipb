{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipB",
  "version": "0.8.0-beta.1",
  "identifier": "com.farukumaridris.clipb",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClipB",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMUQwRDlFNDcyQzk5RApSV1NkeVhMazJkRHhDVHRRVVd5d2p6TUF6THgySzd4OU5hQnpjY01Ld2tQa20xNmVWblhpR05Gbgo=",
      "endpoints": [
        "https://getclipb.com/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preload": ["sqlite:clipb.db"]
    }
  }
}
